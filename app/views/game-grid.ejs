<%- include("partials/header-game.ejs") %>

<div class="game-container">
  <div class="legend">
    <h2>Légende</h2>
    <ul>
      <% themes.forEach(theme => { %>
        <li>
          <span class="theme-color-box" style="background-color: <%= theme.color %>;"></span>
          <%= theme.theme_name %>
        </li>
    </ul>
    <% }) %>

    <div id="timer-container">
      Temps restant : <span id="timer">30</span>s
    </div>
  </div>

  <div class="grid-container">
    <% game.cards.forEach((card, index) => { %>
      <div class="card" data-question-id="<%= card.id %>" data-number="<%= card.number %>" style="background-color:<%= card.theme_color %>;">
        <div class="card-number"><%= card.number %></div>
      </div>
    <% }) %>
  </div>
</div>

<div id="gameData" data-game='<%- JSON.stringify(game).replace(/'/g, "&apos;") %>'></div>
<script src="/js/game.js"></script>

<%- include("partials/footer.ejs") %>
