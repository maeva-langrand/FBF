<%- include("partials/header.ejs") %>

<main class="question_main">

    <h1 class="question_title">
        <%= mode==="edit" ? "Éditer la question" : "Créer une nouvelle question" %>
    </h1>

    <form class="edit_question_form"
        action="<%= mode === 'edit' ? '/questions/editer/' + question.id : '/questions/nouvelle-question' %>"
        method="POST" enctype="multipart/form-data">

        <!-- Intention de suppression d'imatge/audio-->

           <input type="hidden" name="deleteQuestionImage" id="deleteQuestionImage" value="false">
    <input type="hidden" name="deleteResponseImage" id="deleteResponseImage" value="false">
    <input type="hidden" name="deleteAudio" id="deleteAudio" value="false">

        <!-- QUESTION -->
<div class="form-group">
    <label>Question :</label>

    <!-- TOOLBAR -->
    <div class="mini-toolbar">
        <button type="button" data-cmd="bold"><b>G</b></button>
        <button type="button" data-cmd="italic"><i>I</i></button>
        <button type="button" data-cmd="underline"><u>S</u></button>
        <button type="button" data-cmd="insertUnorderedList">• Liste</button>

        <input type="color" data-cmd="foreColor" title="Couleur texte">
        <input type="color" data-cmd="hiliteColor" title="Surligner">
    </div>

    <!-- EDITEUR -->
    <div id="questionEditor"
         class="mini-editor"
         contenteditable="true"><%- question.question %></div>

    <!-- CHAMP ENVOYÉ AU SERVEUR -->
    <input type="hidden"
           id="questionText"
           name="questionText"
           required>
</div>

        <!-- THÈME -->
        <div class="form-group">
            <label for="question-theme">Modifier le thème :</label>
            <select name="theme" id="question-theme" required>
                <% if (mode==="create") { %>
                    <option value="" disabled selected>— Choisissez un thème —</option>
                <% } else { %>
                    <option selected value="<%= question.theme %>">
                        <%= themes.find(t => t.id === question.theme).theme_name %>
                    </option>
                <% } %>
                <% themes.forEach(theme => { %>
                    <% if (mode==="edit" && theme.id===question.theme) return; %>
                    <option value="<%= theme.id %>"><%= theme.theme_name %></option>
                <% }) %>
            </select>
        </div>

        <!-- IMAGE QUESTION -->
        <div class="form-group" id="question-image-block">
            <label>Image de la question :</label>

            <% if (question.question_image) { %>
                <p>Image actuelle :</p>
                <p><%= question.question_image %></p>
                <img src="/uploads/<%= question.question_image %>" style="max-width:200px;">
                <div>
                    <input type="file" name="questionImage">
                </div>
                <div>
<button type="button"
        class="question_delete_img_btn delete-question-image-btn">
    Supprimer l'image de la question
</button>
                </div>
            <% } else { %>
                <p>Aucune image associée.</p>
                <input type="file" name="questionImage">
            <% } %>
        </div>

        <!-- RÉPONSE -->
<div class="form-group">
    <label>Réponse :</label>

    <div class="mini-toolbar">
        <button type="button" data-cmd="bold"><b>G</b></button>
        <button type="button" data-cmd="italic"><i>I</i></button>
        <button type="button" data-cmd="underline"><u>S</u></button>
        <button type="button" data-cmd="insertUnorderedList">• Liste</button>

        <input type="color" data-cmd="foreColor">
        <input type="color" data-cmd="hiliteColor">
    </div>

    <div id="responseEditor"
         class="mini-editor"
         contenteditable="true"><%- question.response %></div>

    <input type="hidden"
           id="response"
           name="response"
           required>
</div>

        <!-- IMAGE RÉPONSE -->
        <div class="form-group" id="response-image-block">
            <label>Image de la réponse :</label>

            <% if (question.response_image) { %>
                <p>Image actuelle :</p>
                <p><%= question.response_image %></p>
                <img src="/uploads/<%= question.response_image %>" style="max-width:200px;">
                <div>
                    <input type="file" name="responseImage">
                </div>
                <div>
<button type="button"
        class="question_delete_img_btn delete-response-image-btn">
    Supprimer l'image de la réponse
</button>
                </div>
            <% } else { %>
                <p>Aucune image associée.</p>
                <input type="file" name="responseImage">
            <% } %>
        </div>

        <!-- EXTRAT YOUTUBE -->
      <div class="form-group" id="audio-block">
            <label>Extrait sonore (YouTube)</label>
            <p>Collez l'URL de la vidéo YouTube et définissez l'extrait à jouer :</p>

            <input type="url"
                   name="youtubeUrl"
                   placeholder="https://www.youtube.com/watch?v=xxxxx"
                   value="<%= question.youtube_url || '' %>">

            <div class="time-range">
                <label>Début (sec)</label>
                <input type="number"
                       name="youtubeStart"
                       min="0"
                       placeholder="0"
                       value="<%= question.youtube_start || '' %>">

                <label>Fin (sec)</label>
                <input type="number"
                       name="youtubeEnd"
                       min="0"
                       placeholder="30"
                       value="<%= question.youtube_end || '' %>">
            </div>

            <% if (question.youtube_url) { %>
                <p>🎧 Aperçu de l'extrait :</p>

<% const videoId = getYouTubeId(question.youtube_url); %>

<% if (videoId) { %>
<iframe width="300" height="170"
        src="https://www.youtube.com/embed/<%= videoId %>?start=<%= question.youtube_start || 0 %>&end=<%= question.youtube_end || 30 %>"
        frameborder="0" allow="autoplay">
</iframe>
<% } %>

                <div>
<button type="button"
        class="question_delete_img_btn delete-audio-btn">
    Supprimer l’extrait
</button>
                </div>
            <% } %>
        </div>

        <button class="edit_submit_button" type="submit">Enregistrer les modifications</button>
        <a href="/questions" class="edit_submit_cancel">Annuler</a>
    </form>

    <!-- SUPPRESSION QUESTION -->
    <% if (mode==="edit") { %>
        <form class="question_delete_form" action="/questions/supprimer/<%= question.id %>" method="POST"
              onsubmit="return confirm('Voulez-vous vraiment supprimer cette question ?')">
            <button class="edit_delete_question" type="submit">Supprimer cette question</button>
        </form>
    <% } %>




    
</main>

<script src="/js/mini-editor.js"></script>
<script src="/js/question-edit.js"></script>

<%- include("partials/footer.ejs") %>
