<%- include("partials/header.ejs", { pagetitle: "Connexion" }) %>

<main class="connexion_main">

    <h1 class="connexion_title">Connexion administrateur</h1>

    <% if (typeof message !== "undefined") { %>
      <div class="connexion_message"><%= message %></div>
    <% } %>

    <% if (typeof error !== "undefined") { %>
      <div class="connexion_error"><%= error %></div>
    <% } %>

 <% if (admin) { %>
 <a href="/" class="connexion_back_home">← Retour à l'accueil</a>
  <% } %>

    <% if (!admin) { %>
      <form action="/connexion" method="POST" class="connexion_form">
          <div class="form-group">
              <label for="username">Identifiant</label>
              <input type="text" id="username" name="username" placeholder="Admin" required>
          </div>

          <div class="form-group">
              <label for="password">Mot de passe</label>
              <input type="password" id="password" name="password" placeholder="Votre mot de passe" required>
          </div>

          <button type="submit" class="connexion_submit_button">Se connecter</button>
          <a href="/" class="connexion_cancel_button">Retour</a>
      </form>
    <% } %>

</main>

<%- include("partials/footer.ejs") %>
