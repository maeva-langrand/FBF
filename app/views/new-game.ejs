<%- include("partials/header-game.ejs") %>

<main class="main_new_game">
  <h1 class="new_game_title">Nouvelle Partie</h1>

  <form class="new_game_form" action="/partie-en-cours" method="POST" id="newGameForm">
    <div>
      <label for="gameNameInput">Nom de la partie :</label>
      <input type="text" id="gameNameInput" name="gameName" placeholder="Nom de la partie" required>
    </div>

   <div>
  <label>Nombre de joueurs :</label>
  <input type="number" id="playerCount" name="playerCount" min="1" required>
</div>

<div id="playersContainer">
  <!-- Les inputs pour noms des joueurs + thème préféré sont ajoutés ici dynamiquement -->
</div>


    <div>
      <label>Nombre de questions par thème préféré :</label>
      <input type="number" name="questionsPerPreferredTheme" min="1" required>
    </div>

    <div>
      <label>Nombre total de questions :</label>
      <input type="number" name="totalQuestions" min="1" required>
    </div>

    <button id="launchGameBtn" type="button">Commencer la partie ✨</button>
  </form>
</main>

<div id="rulesModal" class="modal_overlay hidden">
  <div class="modal_content">
    <h2>Règles du jeu</h2>

    <ul class="rules_list">
      <li>👥 Les joueurs (ou les équipes) jouent à tour de rôle.</li>
      <li>🔍 Repérez la couleur de votre thème préféré, et retenez l'emplacement de vos questions dans la grille pour maximiser vos chances.</li>
      <li>🃏 Choisissez une carte pour afficher la question.</li>
      <li>⌛ Vous avez 40 secondes pour répondre.</li>
      <li>✅ Bonne réponse = entre 1 et 3 points selon le thème.</li>
    </ul>

    <button id="startGameBtn" class="primary_btn">
      ✨ C’est parti !
    </button>
  </div>
</div>


<div id="themesData" data-themes='<%- JSON.stringify(themes).replace(/'/g, "&apos;") %>'></div>
<script src="/js/new-game.js"></script>


<%- include("partials/footer.ejs") %>